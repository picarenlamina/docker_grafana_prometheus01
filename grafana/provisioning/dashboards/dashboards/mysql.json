      "datasource": "Prometheus",
      "format": "short",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 0 },
      "id": 13,
      "title": "Current QPS (Queries per Second)",
      "type": "singlestat",
      "targets": [
        {
          "expr": "rate(mysql_global_status_queries{job=\"mysql\"}[5m])",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "valueName": "current"
    },
    {
      "aliasColors": {},
      "bars": false,
      "datasource": "Prometheus",
