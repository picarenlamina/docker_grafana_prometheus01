      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "id": 10,
      "legend": { "show": true, "alignAsTable": true, "avg": true, "current": true },
      "lines": true,
      "linewidth": 1,
      "title": "MySQL Connections & Threads",
      "type": "graph",
      "targets": [
        {
          "expr": "mysql_global_status_threads_connected{job=\"mysql\"}",
          "legendFormat": "Threads Connected",
          "refId": "A"
        },
        {
          "expr": "mysql_global_status_threads_running{job=\"mysql\"}",
          "legendFormat": "Threads Running",
          "refId": "B"
        },
        {
          "expr": "mysql_global_variables_max_connections{job=\"mysql\"}",
          "legendFormat": "Max Connections",
          "refId": "C"
        }
      ],
      "xaxis": { "mode": "time", "show": true },
      "yaxes": [{ "format": "short", "min": 0, "show": true }, { "show": false }]
    },
    {
      "aliasColors": {},
      "datasource": "Prometheus",
      "fill": 1,
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "id": 11,
      "title": "InnoDB Buffer Pool Usage",
      "type": "graph",
      "targets": [
        {
          "expr": "mysql_global_status_innodb_buffer_pool_pages_data{job=\"mysql\"} * 16384",
          "legendFormat": "Data Bytes",
          "refId": "A"
        },
        {
          "expr": "mysql_global_variables_innodb_buffer_pool_size{job=\"mysql\"}",
          "legendFormat": "Total Pool Size",
          "refId": "B"
        }
      ],
      "xaxis": { "mode": "time", "show": true },
      "yaxes": [{ "format": "bytes", "min": 0, "show": true }, { "show": false }]
    }
